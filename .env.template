# Psytrance Night Outreach Agent — Environment Configuration
# Copy this file to .env and fill in your values.

# === REQUIRED ===
# OpenAI API key for GPT-4o (vibe check, pitch generation, vision, sentiment)
OPENAI_API_KEY=

# === EMAIL (required for dispatch) ===
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=

# === IMAP (required for automated response ingestion) ===
IMAP_SERVER=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# === PROXY (optional — for bypassing anti-bot) ===
# Comma-separated list: http://user:pass@host:port
# PROXY_LIST=

# === GOOGLE MAPS API (optional fallback for Maps Playwright scraper) ===
# GOOGLE_MAPS_API_KEY=

# === DATABASE (optional — override default path) ===
# DB_PATH=database/outreach.db
